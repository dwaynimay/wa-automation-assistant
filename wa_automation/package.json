{
  "name": "wa_automation",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:python\"",
    "dev:vite": "vite",
    "dev:python": "backend/venv/bin/python backend/server.py",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint ./**/*.{ts,js}",
    "lint:fix": "eslint ./**/*.{ts,js} --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.1.3",
    "vite-plugin-monkey": "^5.0.9"
  }
}